# Testnet profile: Polymesh public testnet + Ethereum Sepolia.
# See bridge/TESTNET.md for faucets, deploy, and first transfer.
#
# Usage:
#   cp bridge/envs/testnet.env bridge/relayer/.env.testnet
#   # fill secrets + deployed addresses
#   cd bridge/relayer && yarn start:testnet
#
# NEVER commit real private keys or mnemonics.

BRIDGE_NETWORK=testnet

# --- Ethereum Sepolia ---
# Prefer a dedicated RPC (Alchemy / Infura / QuickNode). Public endpoints rate-limit.
BRIDGE_ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BRIDGE_ETH_CHAIN_ID=11155111
# Relayer hot wallet private key (Sepolia ETH for gas). Must match on-chain relayer().
BRIDGE_ETH_RELAYER_KEY=
# Higher confirmations than Anvil
BRIDGE_ETH_CONFIRMATIONS=3
# Filled after: ./bridge/scripts/deploy-eth.sh --network sepolia
BRIDGE_ADDRESS=0x0000000000000000000000000000000000000000
WPOLYX_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: Etherscan API key for forge verify
# ETHERSCAN_API_KEY=

# --- Polymesh public testnet ---
# Docs: https://developers.polymesh.network/developer-resources/links/
POLYMESH_NODE_URL=wss://testnet-rpc.polymesh.live/
POLYMESH_GRAPHQL_URL=https://testnet-graphql.polymesh.live/
# Escrow account mnemonic (testnet only). Fund with test POLYX — see TESTNET.md.
BRIDGE_POLYMESH_ESCROW_MNEMONIC=

# --- Relayer ---
BRIDGE_POLL_INTERVAL_MS=6000
BRIDGE_POLYMESH_FINALITY_BLOCKS=10
BRIDGE_DB_PATH=./bridge-state.testnet.db
BRIDGE_INTENT_API_PORT=3006
# Use a strong random token if the API is reachable beyond localhost
BRIDGE_API_TOKEN=
BRIDGE_API_RATE_WINDOW_MS=60000
BRIDGE_API_RATE_MAX=20
BRIDGE_MIN_AMOUNT_POLYX=0.01
BRIDGE_MAX_AMOUNT_POLYX=1000
BRIDGE_DAILY_VOLUME_POLYX=10000
