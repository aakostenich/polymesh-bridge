{
  "name": "polymeth-bridge-relayer",
  "version": "0.1.0",
  "description": "Two-way POLYX <-> wPOLYX bridge relayer between Polymesh and a local Ethereum (Anvil) chain.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/relayer.ts",
    "start:local": "BRIDGE_NETWORK=local tsx src/relayer.ts",
    "start:testnet": "BRIDGE_NETWORK=testnet tsx src/relayer.ts",
    "bootstrap": "tsx src/ops/bootstrap-escrow.ts",
    "lock": "tsx src/ops/lock-polyx.ts",
    "addresses": "tsx src/ops/print-addresses.ts",
    "addresses:testnet": "BRIDGE_NETWORK=testnet tsx src/ops/print-addresses.ts",
    "check": "tsx src/ops/check-ready.ts",
    "check:testnet": "BRIDGE_NETWORK=testnet tsx src/ops/check-ready.ts",
    "e2e": "../scripts/e2e-bridge.sh",
    "e2e:restart": "../scripts/e2e-bridge.sh --restart",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@polymeshassociation/local-signing-manager": "^4.1.1",
    "@polymeshassociation/polymesh-sdk": "30.0.0",
    "better-sqlite3": "^11.8.1",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.5.0",
    "ethers": "^6.13.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.17",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "resolutions": {
    "@polkadot/api": "16.5.2",
    "@polkadot/api-augment": "16.5.2",
    "@polkadot/api-base": "16.5.2",
    "@polkadot/api-derive": "16.5.2",
    "@polkadot/rpc-augment": "16.5.2",
    "@polkadot/rpc-core": "16.5.2",
    "@polkadot/rpc-provider": "16.5.2",
    "@polkadot/types": "16.5.2",
    "@polkadot/types-augment": "16.5.2",
    "@polkadot/types-known": "16.5.2"
  },
  "packageManager": "yarn@4.9.2"
}
