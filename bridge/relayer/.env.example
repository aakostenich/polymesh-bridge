# Bridge relayer configuration. Copy to `.env` and adjust.
#
# After running `bridge/scripts/deploy-eth.sh`, copy the printed
# WPOLYX_ADDRESS and BRIDGE_ADDRESS into the two variables below.

# --- Ethereum (Anvil, started with `--profile eth`) ---
BRIDGE_ETH_RPC_URL=http://127.0.0.1:8546
BRIDGE_ETH_CHAIN_ID=1337
# Anvil account[1] private key — must match RELAYER_ADDRESS passed to deploy-eth.sh.
BRIDGE_ETH_RELAYER_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
BRIDGE_ETH_CONFIRMATIONS=2

# Deployed contract addresses (fill after deploy-eth.sh)
BRIDGE_ADDRESS=0x0000000000000000000000000000000000000000
WPOLYX_ADDRESS=0x0000000000000000000000000000000000000000

# --- Polymesh (from this repo's dev-env) ---
POLYMESH_NODE_URL=ws://127.0.0.1:9944
POLYMESH_GRAPHQL_URL=http://127.0.0.1:3000
# Escrow account. On the dev chain, Alice (//Alice) is the funded sudo key.
# Bootstrap funds this account from Alice; keep it well-funded so Eth->Poly
# releases always succeed.
BRIDGE_POLYMESH_ESCROW_MNEMONIC=//Charlie

# --- Relayer behaviour ---
BRIDGE_POLL_INTERVAL_MS=4000
BRIDGE_POLYMESH_FINALITY_BLOCKS=5
BRIDGE_DB_PATH=./bridge-state.db
BRIDGE_INTENT_API_PORT=3006

# --- API auth (Bearer token) ---
# Default if unset: dev-bridge-token. Set to "off" to disable (local only).
BRIDGE_API_TOKEN=dev-bridge-token
# Rate limit for POST /lock-intent (per client IP)
BRIDGE_API_RATE_WINDOW_MS=60000
BRIDGE_API_RATE_MAX=30

# --- Transfer caps (human POLYX amounts, 6 decimals) ---
BRIDGE_MIN_AMOUNT_POLYX=0.01
BRIDGE_MAX_AMOUNT_POLYX=10000
BRIDGE_DAILY_VOLUME_POLYX=100000
