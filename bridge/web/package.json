{
  "name": "polymesh-bridge-web",
  "version": "0.1.0",
  "private": true,
  "description": "Local demo UI for the POLYX ↔ wPOLYX bridge",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,ui -c cyan,magenta \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:local": "BRIDGE_NETWORK=local concurrently -k -n api,ui -c cyan,magenta \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:testnet": "BRIDGE_NETWORK=testnet concurrently -k -n api,ui -c cyan,magenta \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:ui": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@polymeshassociation/local-signing-manager": "^4.1.1",
    "@polymeshassociation/polymesh-sdk": "30.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ethers": "^6.13.4",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^6.0.7"
  },
  "resolutions": {
    "@polkadot/api": "16.5.2"
  }
}
